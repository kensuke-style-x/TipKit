import UIKit
import TipKit



class ViewController: UIViewController {
    
    @IBOutlet weak var starButton: UIButton!
    
    private var tipstar = Tipstar()
    
    private weak var tipView: TipUIView?
    
    private var tipObservationTask: Task<Void, Never>?
    
    private weak var tipPopoverController: TipUIPopoverViewController?
    
    
    @IBAction func starButtonTapped(_ sender: Any) {
        
       
       hideTipStar()
        
    }
    
    
    override func viewDidLoad() {
        super.viewDidLoad()
        // Do any additional setup after loading the view.
        
       
        //TipUIVIew
        showTipstar()

        //TipUIpopoverview
        showTipstarPopover()
    }

 //TipUIView

    func showTipstar(){
        
        tipObservationTask = tipObservationTask ?? Task { @MainActor in
         
            for await shouldDisplay in tipstar.shouldDisplayUpdates{
                
                if shouldDisplay {
                    
                    let tipStarview = TipUIView(tipstar, arrowEdge: .bottom)
                     
                     tipStarview.translatesAutoresizingMaskIntoConstraints = false
                     
                     view.addSubview(tipStarview)
                    
                     NSLayoutConstraint.activate([
                         tipStarview.bottomAnchor.constraint(equalTo: starButton.topAnchor, constant: -8),
                         tipStarview.centerXAnchor.constraint(equalTo: starButton.centerXAnchor)
                     ])
                    
                    tipView = tipStarview
                    
                } else {
                    
                    tipView?.removeFromSuperview()
                    
                    tipView = nil
                }
                
            }
        }
        
       
        
    }

//TipPopoverUIView

    func showTipstarPopover(){
        
        tipObservationTask = tipObservationTask ?? Task{ @MainActor in
        
            for await shouldDisplay in tipstar.shouldDisplayUpdates{
                
                if shouldDisplay{
                    
                    let popoverController = TipUIPopoverViewController(tipstar, sourceItem: starButton)
                    present(popoverController, animated: true)
                    tipPopoverController = popoverController
                    
                } else {
                    if presentedViewController is TipUIPopoverViewController{
                        dismiss(animated: true)
                        tipPopoverController = nil
                    }
                }
            }
            
        }
        
        
        
    }

    func hideTipStar(){
        
        tipView?.removeFromSuperview()
        
        tipView = nil
    }
            
        
        
       
        
    

    
    
    
}

